{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/en/", "destination": "/index.html" },
    { "source": "/en", "destination": "/index.html" },
    { "source": "/tr/", "destination": "/tr/index.html" },
    { "source": "/tr", "destination": "/tr/index.html" },
    { "source": "/en/product/alkosafe-saliva-alcohol-test", "destination": "/en/product/alkosafe-saliva-alcohol-test.html" },
    { "source": "/tr/urun/alkosafe-tukuruk-alkol-testi", "destination": "/tr/urun/alkosafe-tukuruk-alkol-testi.html" },
    { "source": "/en/how-it-works", "destination": "/en/how-it-works.html" },
    { "source": "/en/how-it-works/", "destination": "/en/how-it-works.html" },
    { "source": "/tr/nasil-calisir", "destination": "/tr/nasil-calisir.html" },
    { "source": "/tr/nasil-calisir/", "destination": "/tr/nasil-calisir.html" },
    { "source": "/en/compliance", "destination": "/en/compliance.html" },
    { "source": "/en/compliance/", "destination": "/en/compliance.html" },
    { "source": "/tr/sertifikalar", "destination": "/tr/sertifikalar.html" },
    { "source": "/tr/sertifikalar/", "destination": "/tr/sertifikalar.html" }
